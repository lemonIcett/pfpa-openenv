# ── PFPA OpenEnv — Environment Variables ──────────────────────────────────────
# Copy this file to .env, fill in your values, then run:
#   export $(cat .env | xargs) && python deploy_to_hf.py
#
# NEVER commit .env to git — it contains secrets.

# Your Hugging Face username (e.g. john-doe)
HF_USERNAME=

# Your Hugging Face access token (create at https://huggingface.co/settings/tokens)
# Read+Write token required for deploying Spaces
HF_TOKEN=hf_...

# Name for your HF Space repo (default: pfpa-openenv)
SPACE_NAME=pfpa-openenv

# HuggingFace inference router — free, no OpenAI key needed
API_BASE_URL=https://router.huggingface.co/v1

# Any HF-hosted model identifier
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# URL of the running environment (local dev default)
ENV_URL=http://localhost:7860
